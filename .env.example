# Discord Bot トークン（必須）
DISCORD_TOKEN=your_discord_bot_token

# スラッシュコマンドを登録する対象ギルド ID（必須）
DISCORD_GUILD_ID=your_guild_id_here

# 読み上げ対象テキストチャンネルの初期値（必須）
DISCORD_YOMIAGE_CH_ID=your_channel_id_here

# VOICEVOX Engine の URL（任意、既定: http://localhost:50021）
VOICEVOX_BASE_URL=http://localhost:50021

# AIVoice2 Engine の URL（任意、既定: http://localhost:8000）
AIVOICE2_ENGINE_BASE_URL=http://localhost:8000

# ユーザー音声設定 JSON のパス（任意、既定: data/voice_settings.json）
# VOICE_SETTINGS_PATH=data/voice_settings.json

# ログレベル（任意、既定: info）。例: info / debug / yomiage=debug
RUST_LOG=info

# ログ形式（任意）。json を指定すると構造化 JSON で出力する
# LOG_FORMAT=json

# --- 「空気読み」系機能（任意、いずれもデフォルト有効） ---
# 誰かが VC で喋っている間は読み上げを保留し、沈黙後に読む
# YOMIAGE_WAIT_WHILE_SPEAKING=true
# 同一ユーザーの連投を 1 発話にまとめる
# YOMIAGE_MERGE_BURSTS=true
# Bot と同じ VC にいないユーザーのメッセージは読み上げない
# YOMIAGE_SKIP_NON_VC=true
# 沈黙とみなすまでの時間（ミリ秒、既定 500）
# YOMIAGE_QUIET_THRESHOLD_MS=500
